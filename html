<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Pranathi | Portfolio</title>

    <link rel="stylesheet" href="style.css">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">

    <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

</head>

<body>

    <!-- Loader -->

    <div id="loader">
        <div class="spinner"></div>
    </div>

    <!-- Navbar -->

    <header>

        <nav>

            <h2 class="logo">Pranathi</h2>

            <ul id="menu">

                <li><a href="#home">Home</a></li>

                <li><a href="#about">About</a></li>

                <li><a href="#skills">Skills</a></li>

                <li><a href="#projects">Projects</a></li>

                <li><a href="#contact">Contact</a></li>

            </ul>

            <div class="icons">

                <i class="fa-solid fa-moon" id="themeBtn"></i>

                <i class="fa-solid fa-bars" id="menuBtn"></i>

            </div>

        </nav>

    </header>

    <!-- Hero -->

    <section id="home">

        <div class="left">

            <h3>Hello 👋</h3>

            <h1>I'm Pranathi</h1>

            <h2><span id="typing"></span></h2>

            <p>

                Passionate Computer Science student with strong knowledge in
                Python, SQL and Web Development.

            </p>

            <div class="buttons">

                <a href="#projects" class="btn">View Projects</a>

                <a href="resume.pdf" class="btn2" download>Download Resume</a>

            </div>

            <div class="social">

                <a href="#"><i class="fab fa-github"></i></a>

                <a href="#"><i class="fab fa-linkedin"></i></a>

                <a href="#"><i class="fab fa-instagram"></i></a>

            </div>

        </div>

        <div class="right">

            <img src="images/profile.jpg" alt="Profile">

        </div>

    </section>

    <!-- About -->

    <section id="about">

        <h2 class="title">About Me</h2>

        <p>

            I'm currently pursuing B.Tech in Computer Science Engineering.

            I love building Python projects and learning new technologies.
            My goal is to become a Software Developer.

        </p>

    </section>

    <!-- Skills -->

    <section id="skills">

        <h2 class="title">Skills</h2>

        <div class="skill">

            <span>Python</span>

            <div class="bar">
                <div class="python"></div>
            </div>

        </div>

        <div class="skill">

            <span>SQL</span>

            <div class="bar">
                <div class="sql"></div>
            </div>

        </div>

        <div class="skill">

            <span>HTML</span>

            <div class="bar">
                <div class="html"></div>
            </div>

        </div>

        <div class="skill">

            <span>CSS</span>

            <div class="bar">
                <div class="css"></div>
            </div>

        </div>

        <div class="skill">

            <span>JavaScript</span>

            <div class="bar">
                <div class="js"></div>
            </div>

        </div>

    </section>

    <!-- Projects -->

    <section id="projects">

        <h2 class="title">Projects</h2>

        <div class="project-container">

            <div class="card">

                <h3>Student Management System</h3>

                <p>

                    Python based project with CRUD operations.

                </p>

                <button>GitHub</button>

            </div>

            <div class="card">

                <h3>Portfolio Website</h3>

                <p>

                    Responsive portfolio using HTML CSS JavaScript.

                </p>

                <button>GitHub</button>

            </div>

            <div class="card">

                <h3>Weather App</h3>

                <p>

                    Uses API to fetch weather information.

                </p>

                <button>GitHub</button>

            </div>

        </div>

    </section>

    <!-- Contact -->

    <section id="contact">

        <h2 class="title">Contact</h2>

        <form>

            <input type="text" placeholder="Your Name">

            <input type="email" placeholder="Email">

            <textarea placeholder="Message"></textarea>

            <button>Send</button>

        </form>

    </section>

    <!-- Footer -->

    <footer>

        <p>

            © 2026 Pranathi | Designed with ❤️

        </p>

    </footer>

    <button id="topBtn">

        ↑

    </button>

    <script src="script.js"></script>

</body>

</html>
